	range: rdfs:Literal  or  xsd:string
	Annotations: rdfs:label "Dado para concursar:  recurso.final  Deve ser formatado como (rdfs:Literal  or  xsd:string)"@pt
	Annotations: bim:Chave "d.concu.109"
	Annotations: bim:Ação "Ação de concursar"@pt
	Annotations: bim:Definição "Declara que é um recurso final aberto no contexto do concurso, licitação ou certame."@pt
	Annotations: bim:Definición "Declara que se trata de un recurso de impugnación abierto en el contexto de la licitación, licitación o concurso."@es
	Annotations: bim:Definition "It declares that it is a final appeal opened in the context of the tender, bidding or contest."@en

