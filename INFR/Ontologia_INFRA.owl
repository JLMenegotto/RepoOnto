ObjectProperty: bim:p.esgotar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.a.jusante.de
	SubPropertyOf: bim:p.esgotar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a esgotar: é.a.jusante.de"@pt
	Annotations: bim:Chave "d.esgot.113"
	Annotations: bim:Ação "Ação de esgotar"@pt
	Annotations: bim:Definição "Declara que o objeto é posicionado a jusante de outro objeto (no sentido do fluxo). Propriedade pensada para ordenar elementos de desagues e tubulações."@pt
	Annotations: bim:Definición "Declara que el objeto está situado aguas abajo de otro objeto (en la dirección del flujo). Propiedad diseñada para ordenar elementos de caudales y tuberías."@es
	Annotations: bim:Definition "It declares that the object is positioned downstream of another object (in the direction of the flow). Property designed to order elements of flows and pipes."@en
	Characteristics: Transitive
	Characteristics: Asymmetric
	InverseOf: bim:é.a.montante.de

