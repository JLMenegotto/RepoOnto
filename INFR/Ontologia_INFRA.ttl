                    rdfs:range               [rdf:type rdfs:Datatype ; owl:unionOf ( rdfs:Literal  xsd:string) ]  ;
                    rdfs:label              " [rdf:type rdfs:Datatype ; owl:unionOf ( Dado para abastecer:  abastecedor.de  Deve ser formatado como (rdfs:Literal  xsd:string)) ] " ;
                    bim:Chave               "abast.100" ;
                    bim:Ação                "Ação de abastecer" ;
                    bim:Definição           "Declara que é um elemento que abastece a algum outro elemento. "@pt ;
                    bim:Definición          "Declara que es un elemento que suministra a otro elemento."@es ;bim:Definition          "Declares that it is an element that supplies some other element."@en  .


