bim:Identifica		 rdf:type   owl:AnnotationProperty .
bim:Parâmetro		 rdf:type   owl:AnnotationProperty .
bim:Explicação		 rdf:type   owl:AnnotationProperty .
bim:Explicación		 rdf:type   owl:AnnotationProperty .
bim:Explanation		 rdf:type   owl:AnnotationProperty .
bim:Advertência.1		 rdf:type   owl:AnnotationProperty .
bim:Aviso		 rdf:type   owl:AnnotationProperty .
bim:Warning		 rdf:type   owl:AnnotationProperty .

