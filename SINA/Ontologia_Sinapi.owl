ObjectProperty: bim:p.identificar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.alias
	SubPropertyOf: bim:p.identificar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a identificar: é.alias"@pt
	Annotations: bim:Chave "ident.100"
	Annotations: bim:Ação "Ação identificar"@pt
	Annotations: bim:Definição "Declara o pseudônimo ou nome alternativo de um objeto ou agente. Pode ser utilizado para identificar prédios, cidades, pessoas, etc. Por exemplo, Rio de Janeiro é um nome, Cidade Maravilhosa o alias."@pt
	Annotations: bim:Definición "Identifica el nombre alternativo de un objeto o agente. Puede usarse para identificar edificios, ciudades, personas, etc. Por ejemplo, Río de Janeiro es un nombre, Ciudad Maravillosa es el alias."@es
	Annotations: bim:Definition "Identifies the alternative name of an object or agent. It can be used to identify buildings, cities, people, etc. For example, Rio de Janeiro is a name, Marvelous City the alias."@en
	EquivalentTo: bim:é.apelido

DataProperty: bim:d.identificar
	SubPropertyOf: bim:BIMData



DataProperty: bim:alias
