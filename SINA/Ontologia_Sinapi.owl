	range: rdfs:Literal  or  xsd:string
	Annotations: rdfs:label "Dado para funcionar:  ocupante  Deve ser formatado como (rdfs:Literal  or  xsd:string)"@pt
	Annotations: bim:Chave "funci.108"
	Annotations: bim:Ação "Ação funcionar"@pt
	Annotations: bim:Definição "Declara o nome do ocupante de um ambiente, setor ou entidade espacial."@pt
	Annotations: bim:Definición "Declara el nombre del ocupante de un espacio, sector o entidad espacial."@es
	Annotations: bim:Definition "Declares the name of the occupant of a space, sector, or spatial entity."@en

