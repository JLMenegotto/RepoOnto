	SubPropertyOf: bim:d.sensorizar
	range: rdfs:Literal  or  xsd:string
	Annotations: rdfs:label "Dado para sensorizar:  câmera.termográfica  Deve ser formatado como (rdfs:Literal  or  xsd:string)"@pt
