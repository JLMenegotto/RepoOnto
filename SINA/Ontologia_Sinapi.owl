	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a abastecer: é.abastecedor.de"@pt
	Annotations: bim:Chave "abast.100"
	Annotations: bim:Ação "Ação abastecer"@pt
	Annotations: bim:Definição "Declara que é um elemento que abastece a algum outro elemento."@pt
	Annotations: bim:Definición "Declara que es un elemento que proporciona algún otro elemento."@es
	Annotations: bim:Definition "Declares that it is an element that supplies some other element."@en
