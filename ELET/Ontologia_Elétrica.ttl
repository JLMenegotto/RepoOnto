                    rdfs:range              bim:Projeto ;
                    rdfs:label              "Propriedade destinada a abastecer: é.abastecedor.de" ;
                    bim:Chave               "abast.100" ;
                    bim:Ação                "Ação abastecer" ;
                    bim:Definição           "Declara que é um elemento que abastece a algum outro elemento."@pt ;
                    bim:Definición          "Declara que es un elemento que proporciona algún otro elemento."@es ;bim:Definition          "It declares that it is an element that supplies some other element."@en ;
                    rdf:type                owl:IrreflexiveProperty ;
                    owl:inverseOf           bim:é.abastecido.por  .


