	Annotations: rdfs:label "Segmento.de.Descida"@pt
	Annotations: bim:Definição "Conta-gotas é um transportador de cabo usado para suspender o cabo de outro cabo."@pt
	Annotations: bim:Definición "El cuentagotas es un portador de cable que se utiliza para suspender el cable de otro cable."@es
