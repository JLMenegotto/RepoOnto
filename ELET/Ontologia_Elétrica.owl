Class: bim:Condutos.Segmentos
	Annotations: rdfs:label "Condutos Segmentos"@pt
	SubClassOf: bim:Elementos.Elétricos


Class: bim:Segmento.de.Calha
	Annotations: rdfs:label "Segmento.de.Calha"@pt
	Annotations: bim:Definição "Segmentos de portador de cabo é um segmentos de fluxo usado especificamente para transportar e suportar cabeamento."@pt
	Annotations: bim:Definición "Los segmentos de portadores de cable son un segmento de flujo que se utiliza específicamente para transportar y soportar el cableado."@es
	Annotations: bim:Definition "Cable carrier segments is a flow segment used specifically to carry and support cabling."@en
	Annotations: bim:Natureza "EletroTécnico"@pt
	Annotations: bim:Espécie "Elementos.Elétricos"@pt
	Annotations: bim:Tema "Condutos.Segmentos"@pt
	Annotations: bim:Disciplina "Instalações"@pt
	Annotations: bim:Chave "Key-ELE-39"
	Annotations: bim:CatRevit "[ OST_CableTray , OST_CableTrayCenterLine , OST_CableTrayDrop , OST_CableTrayRiseDrop , OST_CableTrayRun ]"
	Annotations: bim:ClasseIfc "[ IfcCableCarrierSegment ]"
	Annotations: bim:ABNT "[ 3E.26 ]"
	SubClassOf: bim:Condutos.Segmentos


Class: bim:Segmento.de.Suporte
	Annotations: rdfs:label "Segmento.de.Suporte"@pt
	Annotations: bim:Definição "Suporte de cabo é um suporte de cabo horizontal fixado em apenas uma extremidade, espaçado em intervalos."@pt
	Annotations: bim:Definición "El soporte de cable es un soporte de cable horizontal fijado en un solo extremo, espaciado a intervalos."@es
	Annotations: bim:Definition "Cable holder is a horizontal cable holder fixed at only one end, spaced at intervals."@en
	Annotations: bim:Natureza "EletroTécnico"@pt
	Annotations: bim:Espécie "Elementos.Elétricos"@pt
	Annotations: bim:Tema "Condutos.Segmentos"@pt
	Annotations: bim:Disciplina "Instalações"@pt
	Annotations: bim:Chave "Key-ELE-40"
	Annotations: bim:CatRevit "[ OST_CableTray , OST_CableTrayCenterLine , OST_CableTrayDrop , OST_CableTrayRiseDrop , OST_CableTrayRun ]"
	Annotations: bim:ClasseIfc "[ IfcCableCarrierSegmentCABLEBRACKET ]"
	Annotations: bim:ABNT "[ 3E.26 ]"
	SubClassOf: bim:Condutos.Segmentos


