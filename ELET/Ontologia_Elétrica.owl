ObjectProperty: bim:é.limite.de.escoamento
	SubPropertyOf: bim:p.resistir
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a resistir: é.limite.de.escoamento"@pt
	Annotations: bim:Chave "resis.119"
	Annotations: bim:Ação "Ação resistir"@pt
	Annotations: bim:Definição "Declara o limite de escoamento em MPA. É o valor crítico em que o aço muda o comportamento de elástico para plástico, ou seja que não se recupera da deformação."@pt
	Annotations: bim:Definición "Declara el límite elástico en MPA. Es el valor crítico en el que el acero cambia el comportamiento de elástico a plástico, es decir, que no se recupera de la deformación."@es
	Annotations: bim:Definition "Declares the yield strength in MPA. It is the critical value at which steel changes behavior from elastic to plastic, i.e. that it does not recover from deformation."@en
	EquivalentTo: bim:é.limite.elástico

