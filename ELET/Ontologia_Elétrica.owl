ObjectProperty: bim:p.sensorizar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.câmera.termográfica
	SubPropertyOf: bim:p.sensorizar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a sensorizar: é.câmera.termográfica"@pt
	Annotations: bim:Chave "senso.121"
	Annotations: bim:Ação "Ação sensorizar"@pt
	Annotations: bim:Definição "Declara o ID de Revit ou GlobalId IFC ou código identificador de uma câmera termográfica. Sensor para medição de temperatura que exibe termograma ou imagem térmica do objeto emissor da energia infravermelha. Usadas para detectar problemas de superaquecimento de equipamentos, presença de umidade em paredes, etc."@pt
	Annotations: bim:Definición "Declara el ID de Revit o el código IFC GlobalId o identificador de una cortina fotoeléctrica. Transmite señal ultrasónica y detecta la intensidad del eco para detectar objetos y formas."@es
	Annotations: bim:Definition "Declares the Revit ID or IFC GlobalId or identifier code of a thermal imaging camera. Sensor for temperature measurement that displays thermogram or thermal image of the object emitting infrared energy. Used to detect problems of equipment overheating, presence of moisture in walls, etc."@en
	Annotations: bim:CatRevit "OST_SecurityDevices"
	Annotations: bim:ClasseIfc "IfcSensor"
	EquivalentTo: bim:é.sensor.térmico

