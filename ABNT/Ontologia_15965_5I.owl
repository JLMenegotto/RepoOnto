ObjectProperty: bim:é.superfície.de.trabalho
	SubPropertyOf: bim:p.iluminar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a iluminar: é.superfície.de.trabalho"@pt
	Annotations: bim:Chave "d.ilumi.119"
	Annotations: bim:Ação "Ação de iluminar"@pt
	Annotations: bim:Definição "Declara a altura da superfície de trabalho para o qual a iluminância é calculada. Normalmente a 0.75 m do piso. (NBR 15215-3)."@pt
	Annotations: bim:Definición "Declara NBR 15215-3: Declara la altura de la superficie de trabajo para la que se calcula la iluminancia. Normalmente a 0,75 m del suelo. (NBR 15215-3)."@es
	Annotations: bim:Definition "It declares the height of the work surface for which the illuminance is calculated. Usually 0.75 m from the floor. (NBR 15215-3)."@en
	Annotations: bim:CatRevit "[ OST_ElectricalDevices ]"
	Annotations: bim:ClasseIfc "[ IfcLamp ]"
	Annotations: bim:ABNT "[ 0P.70.30.10 ]"
	EquivalentTo: bim:é.superfície.de.referência

