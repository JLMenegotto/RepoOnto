ObjectProperty: bim:p.iluminar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.iluminador.de
	SubPropertyOf: bim:p.iluminar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a iluminar: é.iluminador.de"@pt
	Annotations: bim:Chave "ilumi.100"
	Annotations: bim:Ação "Ação iluminar"@pt
	Annotations: bim:Definição "Declara o ID de Revit ou GlobalId IFC ou identificador único de objeto. Identifica uma entidade de iluminação. Pode ser uma luminária ou poste de luz."@pt
	Annotations: bim:Definición "Declara el ID de Revit o IFC GlobalId o un identificador único de objeto. Identifica una entidad de iluminación. Puede ser una lámpara o un poste de luz."@es
	Annotations: bim:Definition "Declares the Revit ID or IFC GlobalId or unique object identifier. Identifies a lighting entity. It can be a lamp or light pole."@en
	Annotations: bim:CatRevit "[ OST_ElectricalDevices ]"
	Annotations: bim:ClasseIfc "[ IfcLamp ]"
	Annotations: bim:ABNT "[ 0P.70.30 ]"
	InverseOf: bim:é.iluminado.por

