      bim:Espécie     "ABNT"@pt ;
      bim:Tema        "Parte"@pt ;
      bim:Disciplina  "Interdiciplinar"@pt ;
      bim:Chave       "Key.ABNT.2"@pt ;
      bim:CatRevit    "OST_Rooms"   ;
      bim:ClasseIfc   "IfcSpace"   ;
      bim:ABNT        "4A"    .

