#     Classes em Turtle                                          
#################################################################


bim:Projeto rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:BIM  .


bim:Norma rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Projeto ;
      rdfs:label  "Norma"@pt  .


bim:ABNT rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Norma ;
      rdfs:label  "ABNT"@pt  .


bim:Parte rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:ABNT ;
      rdfs:label  "Parte"@pt  .


bim:Código.ABNT rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Parte ;
      rdfs:label  "Código.ABNT"@pt ;
      bim:Definição   "Código ABNT do sistema de classificação da construção do Brasil. NBR 15.965."@pt ;
      bim:Definición  "Código ABNT del Sistema de Classificación de la Construcción de Brasil.  NBR 15.965."@es ;
       bim:Definition  "ABNT code of the construction classification system in Brazil. NBR 15.965."@en ;
