bim:é.coeficiente.de.redução.de.ruido   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.audibilizar ;
                    rdfs:domain             bim:BIM ;
                    rdfs:range              bim:Projeto ;
                    rdfs:label              "Propriedade destinada a audibilizar: é.coeficiente.de.redução.de.ruido" ;
                    bim:Chave               "audib.112" ;
                    bim:Ação                "Ação audibilizar" ;
                    bim:Definição           "Declara propriedade acústica: quantidade de energia sonora absorvida Noise Reduction Coefficient (NRC). O Coeficiente de Redução de Ruído indica quanto som um material consegue absorver em um ambiente.   - Nota: o Object property é usado para qualificar ou relacionar indivíduos. O Data property para lhes atribuir um valor."@pt ;
                    bim:Definición          "Declara propiedad acústica: cantidad de energía sonora absorbida como Coeficiente de Reducción de Ruido (NRC). El Coeficiente de Reducción de Ruido indica cuánto sonido puede absorber un material en un entorno."@es ;bim:Definition          "Declares acoustic property: the amount of sound energy absorbed as Noise Reduction Coefficient (NRC). The Noise Reduction Coefficient indicates how much sound a material can absorb in an environment."@en ;
                    owl:equivalentProperty  bim:é.nrc  .


