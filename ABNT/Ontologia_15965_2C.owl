ObjectProperty: bim:p.sensorizar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.sensor.térmico
	SubPropertyOf: bim:p.sensorizar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a sensorizar: é.sensor.térmico"@pt
	Annotations: bim:Chave "senso.101"
	Annotations: bim:Ação "Ação sensorizar"@pt
	Annotations: bim:Definição "Declara o ID de Revit ou GlobalId IFC ou identificador único de objeto. Declara um sensor de temperatura e umidade.   - Nota: o Object property é usado para qualificar ou relacionar indivíduos. O Data property para lhes atribuir um valor."@pt
	Annotations: bim:Definición "Declara el ID de Revit o IFC GlobalId o un identificador único de objeto. Identifica un sensor de temperatura y humedad."@es
	Annotations: bim:Definition "Declares the Revit ID or IFC GlobalId or unique object identifier. Identifies a temperature and humidity sensor."@en
	Annotations: bim:CatRevit "[ OST_SecurityDevices ]"
	Annotations: bim:ClasseIfc "[ IfcSensor ]"
	EquivalentTo: bim:é.câmera.termográfica

