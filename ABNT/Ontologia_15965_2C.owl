	Annotations: bim:Definition "NBR 15215-3: Declares the height of the work surface for which the illuminance is calculated. Usually 0.75 m from the floor. (NBR 15215-3)."@en
	Annotations: bim:CatRevit "[ OST_ElectricalDevices ]"
	Annotations: bim:ClasseIfc "[ IfcLamp ]"
	Annotations: bim:ABNT "[ 0P.70.30.10 ]"
	EquivalentTo: bim:é.superfície.de.referência

