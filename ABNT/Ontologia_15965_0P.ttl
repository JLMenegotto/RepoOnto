                    rdfs:subPropertyOf      bim:p.energizar ;
                    rdfs:domain             bim:BIM ;
                    rdfs:range              bim:Projeto ;
                    rdfs:label              "Propriedade destinada a energizar: é.resistência.térmica" ;
