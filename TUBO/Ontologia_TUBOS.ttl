#################################################################
#     Propriedades de Objetos e Dados em Turtle                  
#################################################################


bim:p.abastecer   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:BIMProp  .


bim:é.abastecedor.de   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.abastecer ;
                    rdfs:domain             bim:BIM ;
                    rdfs:range              bim:Projeto ;
                    rdfs:label              "Propriedade destinada a abastecer: é.abastecedor.de" ;
                    bim:Chave               "d.abast.100" ;
                    bim:Ação                "Ação de abastecer" ;
                    bim:Definição           "Declara que é um elemento que abastece a algum outro elemento. "@pt ;
                    bim:Definición          "Declara que es un elemento que suministra a otro elemento."@es ;bim:Definition          "It declares that it is an element that supplies some other element."@en ;
                    rdf:type                owl:IrreflexiveProperty ;
                    owl:inverseOf           bim:é.abastecido.por  .


bim:d.abastecer   rdf:type  owl:DatatypeProperty ;
                    rdfs:subPropertyOf      bim:BIMData  .


bim:abastecedor.de   rdf:type  owl:DatatypeProperty ;
                    rdfs:subPropertyOf      bim:d.abastecer ;
                    rdfs:range               [rdf:type rdfs:Datatype ; owl:unionOf ( rdfs:Literal  xsd:string) ]  ;
                    rdfs:label              " [rdf:type rdfs:Datatype ; owl:unionOf ( Dado para abastecer:  abastecedor.de  Deve ser formatado como (rdfs:Literal  xsd:string)) ] " ;
                    bim:Chave               "d.abast.100" ;
                    bim:Ação                "Ação de abastecer" ;
                    bim:Definição           "Declara que é um elemento que abastece a algum outro elemento. "@pt ;
                    bim:Definición          "Declara que es un elemento que suministra a otro elemento."@es ;bim:Definition          "It declares that it is an element that supplies some other element."@en  .


bim:p.abastecer   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:BIMProp  .


bim:é.abastecido.por   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.abastecer ;
                    rdfs:domain             bim:BIM ;
                    rdfs:range              bim:Projeto ;
                    rdfs:label              "Propriedade destinada a abastecer: é.abastecido.por" ;
                    bim:Chave               "d.abast.101" ;
                    bim:Ação                "Ação de abastecer" ;
                    bim:Definição           "Declara que é um elemento que é abastecido por algum outro elemento. "@pt ;
                    bim:Definición          "Declara que es un elemento que es suministrado por otro elemento."@es ;bim:Definition          "It declares that it is an element that is supplied by some other element."@en ;
                    rdf:type                owl:IrreflexiveProperty ;
                    owl:inverseOf           bim:é.abastecedor.de  .


bim:d.abastecer   rdf:type  owl:DatatypeProperty ;
                    rdfs:subPropertyOf      bim:BIMData  .


bim:abastecido.por   rdf:type  owl:DatatypeProperty ;
