	  rdfs:label "Explicación: Formalización  de elementos de canalizaciones en un projeto BIM. Ontología orientativa de la relación de correspondencia entre Clases IFC y categorías de Revit."@es ;
	  rdfs:label "Explanation: Formalize piping elements in BIM design. Guiding ontology of the correspondence relationship between IFC Classes and Revit categories."@en .

rdf:PlainLiteral        rdf:type  rdfs:Datatype .
