      rdfs:subClassOf  bim:Caixas.Pluviais ;
      rdfs:label  "Tanque de Detenção"@pt ;
      bim:Definição   "Caixa utilizada nos condutores horizontais destinadas a armazenar água temporariamente e liberá-la em uma taxa controlada."@pt ;
      bim:Definición  "Caja utilizada en los conductores horizontales destinada a almacenar agua temporalmente y liberarla a una velocidad controlada."@es ;
       bim:Definition  "Box used in the horizontal conductors intended to temporarily store water and release it at a controlled rate."@en ;
      bim:Natureza    "Redes Prediais"@pt ;
      bim:Espécie     "Traçados"@pt ;
      bim:Tema        "Caixas Pluviais"@pt ;
      bim:Disciplina  "Instalações"@pt ;
      bim:Chave       "Key-TUB-62"@pt ;
      bim:CatRevit    "[ OST_PipeFitting ]"   ;
      bim:ClasseIfc   "[ IfcWasteTerminal ]"   ;
      bim:ABNT        "[ 3E.42 ]"    .


