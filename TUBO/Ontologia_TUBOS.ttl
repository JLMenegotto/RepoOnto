bim:Ralo.Pluvial.Hemisfêrico rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Ralos ;
      rdfs:label  "Ralo Pluvial Hemisfêrico"@pt ;
      bim:Definição   "Ralo com grelha de drenagem de formato de meia esfera (cúpula), para facilitar o escoamento da água pluvial e evitar entupimentos causados por folhas, resíduos sólidos ou objetos maiores."@pt ;
      bim:Definición  "Drenar con una rejilla de drenaje de media esfera (cúpula), para facilitar el drenaje del agua de lluvia y evitar obstrucciones causadas por hojas, residuos sólidos u objetos más grandes."@es ;
       bim:Definition  "Drain with half-sphere (dome) drainage grid, to facilitate the drainage of rainwater and avoid clogs caused by leaves, solid residues or larger objects."@en ;
      bim:Natureza    "Redes Prediais"@pt ;
      bim:Espécie     "Traçados"@pt ;
      bim:Tema        "Ralos"@pt ;
      bim:Disciplina  "Instalações"@pt ;
      bim:Chave       "Key-TUB-70"@pt ;
      bim:CatRevit    "[ OST_PipeFitting ]"   ;
      bim:ClasseIfc   "[ IfcWasteTerminal ]"   ;
      bim:ABNT        "[ 3E.42 ]"    .


