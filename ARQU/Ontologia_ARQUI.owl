	Annotations: bim:Definição "Janela veneziana tem aletas inclinadas que permitem a ventilação e um pouco de entrada de luz. Permitem arejamento constante."@pt
	Annotations: bim:Definición "Ventana veneciana tiene láminas inclinadas que permiten la ventilación y um poco de entrada de luz. Permitem aireación constante."@es
	Annotations: bim:Definition "Venetian window has slanted fins that allow ventilation and a little light to enter. They allow constant aeration."@en
	Annotations: bim:Natureza "Arquitetônico"@pt
	Annotations: bim:Espécie "Elementos de Esquadrias"@pt
	Annotations: bim:Tema "Janelas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-ARQ-244"
	Annotations: bim:CatRevit "[ OST_Windows ]"
	Annotations: bim:ClasseIfc "[ IfcWindow ]"
	Annotations: bim:ABNT "[ 3E.20 ]"
	SubClassOf: bim:Janelas


