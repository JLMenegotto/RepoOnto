<https://github.com/JLMenegotto/RepoOnto#Arquitetônico> rdf:type owl:Ontology ; 
	  rdfs:label "OntologiaPrefixo: bim:"@pt ;
	  rdfs:label "OntologiaTema: Arquitetônico"@pt ;
	  rdfs:label "RaizClass: BIM"@pt ;
	  rdfs:label "RaizProp: BIMProp"@pt ;
	  rdfs:label "RaizData: BIMData"@pt ;
	  rdfs:label "URI: https://github.com/JLMenegotto/RepoOnto#"@pt ;
	  rdfs:label "Autor: Prof. José Luis Menegotto - DEG/POLI/UFRJ"@pt ;
	  rdfs:label "Organização: Escola Politécnica da UFRJ"@pt ;
	  rdfs:label "NormaNúmero: -"@pt ;
	  rdfs:label "Edição: -"@pt ;
	  rdfs:label "ISBN: -"@pt ;
	  rdfs:label "NormaEscopo: -"@pt ;
	  rdfs:label "NormaReferência1: -"@pt ;
	  rdfs:label "NormaReferência2: -"@pt ;
	  rdfs:label "NormaReferência3: -"@pt ;
	  rdfs:label "Observações: Ontologia para descrever elementos Arquitetônicos - Pisos - Paredes - Divisórias e Tetos, Esquadrias, Bancadas..."@pt ;
	  rdfs:label "DataHora: 28/04/2026 13:01:11"@pt ;
	  rdfs:label "Advertência: Traduções ao espanhol e ao inglês incorporadas - As traduções devem ser constantemente revisadas"@pt ;
	  rdfs:label "Aviso: Traducciones integradas al español e inglés - Las traducciones deben revisarse constantemente"@es ;
	  rdfs:label "Alert: Built-in Spanish and English Translations - Translations must be constantly reviewed"@en ;
	  rdfs:label "Prédio: -"@pt ;
	  rdfs:label "Cidade: -"@pt ;
	  rdfs:label "Explicação: Formalizar elementos de arquitetura - Pisos - Paredes - Divisórias e Tetos em projeto BIM. Ontologia orientativa da relação de correspondência entre Classes IFC e categorias Revit."@pt ;
	  rdfs:label "Explicación: Formalizar elementos arquitectónicos - Suelos - Paredes - Tabiques y Techos en proyecto BIM. Ontología guía de la relación de correspondencia entre las clases IFC y las categorías de Revit."@es ;
	  rdfs:label "Explanation: Formalize architectural elements - Floors - Walls - Partitions and Ceilings in BIM project. Guiding ontology of the correspondence relationship between IFC Classes and Revit categories."@en .

rdf:PlainLiteral       rdf:type  rdfs:Datatype .
rdfs:Literal           rdf:type  rdfs:Datatype .
xsd:boolean            rdf:type  rdfs:Datatype .
