      rdfs:subClassOf  bim:Brises ;
      rdfs:label  "Brise Retrátil Horizontal"@pt ;
      bim:Definição   "Elemento de sombreamento tipo Brise de láminas móveis para bloquear a radiação solar que incide verticalmente, como acontece no hemisfério Sul nas fachadas orientadas ao Norte."@pt ;
      bim:Definición  "Brise de lámina móvil para bloquear la radiación solar que incide verticalmente, como ocurre en el hemisferio sur en las fachadas orientadas al Norte."@es ;
       bim:Definition  "Brise-type shading element of movable blades to block solar radiation that falls vertically, as happens in the Southern Hemisphere on north-facing facades."@en ;
      bim:Natureza    "Arquitetônico"@pt ;
      bim:Espécie     "Elementos de Esquadrias"@pt ;
      bim:Tema        "Brises"@pt ;
      bim:Disciplina  "Arquitetura"@pt ;
      bim:Chave       "Key-ARQ-281"@pt ;
      bim:CatRevit    "[ OST_Curtain_Systems , OST_CurtainWallPanels ,  OST_CurtainWallMullions ]"   ;
      bim:ClasseIfc   "[ IfcShadingDeviceSHUTTER ]"    .


