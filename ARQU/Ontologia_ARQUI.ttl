bim:Peça.Sanitária rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:De.Banheiros ;
      rdfs:label  "Peça Sanitária"@pt ;
      bim:Definição   "Terminal sanitário é um aparelho fixo ou terminal geralmente abastecido com água e usado para beber."@pt ;
      bim:Definición  "Terminal sanitario es un aparato fijo o terminal que generalmente se suministra con agua y se utiliza para beber."@es ;
       bim:Definition  "Sanitary terminal is a fixed appliance or terminal usually supplied with water and used for drinking."@en ;
      bim:Natureza    "Arquitetônico"@pt ;
      bim:Espécie     "Elementos Sanitários"@pt ;
      bim:Tema        "De Banheiros"@pt ;
      bim:Disciplina  "Arquitetura"@pt ;
      bim:Chave       "Key-ARQ-295"@pt ;
