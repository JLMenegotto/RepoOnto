bim:Gabarito.Hídrico rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Cotas.Gabaritadas ;
      rdfs:label  "Gabarito Hídrico"@pt ;
      bim:Definição   "Gabarito que define os níveis variáveis de um corpo de água natural, como o mar ou crescentes máximas e mínimas de rios e lagoas. Referência para projetos em zonas litorais ou alagáveis."@pt ;
      bim:Definición  "Medidor que define los niveles variables de un cuerpo de agua natural, como el mar o aumentos máximos y mínimos de ríos y lagunas. Referencia para proyectos en zonas costeras o inundables."@es ;
       bim:Definition  "Gauge that defines the variable levels of a natural body of water, such as the sea or maximum and minimum increases of rivers and lagoons. Reference for projects in coastal or floodable areas."@en ;
      bim:Natureza    "Espacialidade"@pt ;
      bim:Espécie     "Elementos Horizontais"@pt ;
