bim:Gabarito.Subterrâneo rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Cotas.Gabaritadas ;
      rdfs:label  "Gabarito Subterrâneo"@pt ;
      bim:Definição   "Gabarito de profundidade. Pode ser usado para definir a cota superior de um projeto subterrâneo, como linha de metrô ou instalações especiais urbanas. Usado como limite de referência de penetração em profundidade para novos projetos."@pt ;
      bim:Definición  "Calibrador de profundidad. Puede usarse para definir la elevación superior de un proyecto subterráneo, como una línea de metro o instalaciones urbanas especiales. Se utiliza como límite de referencia de penetración de profundidad para nuevos proyectos."@es ;
       bim:Definition  "Depth gauge. Can be used to define the upper elevation of an underground project, such as a subway line or urban special installations. Used as a depth penetration reference limit for new projects."@en ;
      bim:Natureza    "Espacialidade"@pt ;
      bim:Espécie     "Elementos Horizontais"@pt ;
      bim:Tema        "Cotas Gabaritadas"@pt ;
      bim:Disciplina  "Arquitetura"@pt ;
      bim:Chave       "Key-AMB-21"@pt ;
      bim:CatRevit    "[ OST_Levels , OST_LevelHeads ]"   ;
      bim:ClasseIfc   "[ IfcBuildingStorey ]"   ;
      bim:ABNT        "[ 4A.07.10.07 ]"    .


