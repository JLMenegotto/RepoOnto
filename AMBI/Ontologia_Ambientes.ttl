      rdfs:label  "Orientação Solar"@pt  .


bim:Símbolo.de.Norte rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Orientação.Solar ;
      rdfs:label  "Símbolo de Norte"@pt ;
      bim:Definição   "Elemento simbólico de referência da posição do Norte Verdadeiro: marcador de Símbolo de Norte."@pt ;
      bim:Definición  "Elemento de referencia simbólico de la posición del Norte Verdadero: marcador del Símbolo Norte."@es ;
       bim:Definition  "Symbolic reference element of the True North position: North Symbol marker."@en ;
      bim:Natureza    "Espacialidade"@pt ;
      bim:Espécie     "Analítica Espacial"@pt ;
      bim:Tema        "Orientação Solar"@pt ;
      bim:Disciplina  "Arquitetura"@pt ;
      bim:Chave       "Key-AMB-173"@pt ;
      bim:CatRevit    "[ OST_GenericAnnotation ]"   ;
      bim:ClasseIfc   "[ IfcAnnotationSYMBOL ]"   ;
      bim:ABNT        "[ - ]"    .

