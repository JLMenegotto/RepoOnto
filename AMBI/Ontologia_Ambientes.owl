Class: bim:Gabarito.Freático
	Annotations: rdfs:label "Gabarito Freático"@pt
	Annotations: bim:Definição "Gabarito que define o nível da camada superior da água subterrânea."@pt
	Annotations: bim:Definición "Plantilla que define el nivel de la capa superior de agua subterránea."@es
	Annotations: bim:Definition "Template that defines the level of the upper layer of groundwater."@en
	Annotations: bim:Natureza "Espacialidade"@pt
	Annotations: bim:Espécie "Elementos Horizontais"@pt
	Annotations: bim:Tema "Cotas Gabaritadas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-ESP-16"
	Annotations: bim:CatRevit "[ OST_Levels , OST_LevelHeads ]"
	Annotations: bim:ClasseIfc "[ IfcBuildingStorey ]"
	Annotations: bim:ABNT "[ 4A.07.10.07 ]"
	SubClassOf: bim:Cotas.Gabaritadas


Class: bim:Gabarito.Subterrâneo
	Annotations: rdfs:label "Gabarito Subterrâneo"@pt
	Annotations: bim:Definição "Gabarito de profundidade. Pode ser usado para definir a cota superior de um projeto subterrâneo, como linha de metrô ou instalações especiais urbanas. Usado como limite de penetração em profundidade."@pt
	Annotations: bim:Definición "Indicador de profundidad. Puede usarse para definir la elevación superior de un proyecto subterráneo, como una línea de metro o instalaciones especiales urbanas. Se utiliza como límite de penetración de profundidad."@es
	Annotations: bim:Definition "Depth gauge. Can be used to define the upper elevation of an underground project, such as a subway line or urban special facilities. Used as a depth penetration limit."@en
	Annotations: bim:Natureza "Espacialidade"@pt
	Annotations: bim:Espécie "Elementos Horizontais"@pt
	Annotations: bim:Tema "Cotas Gabaritadas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-ESP-17"
	Annotations: bim:CatRevit "[ OST_Levels , OST_LevelHeads ]"
	Annotations: bim:ClasseIfc "[ IfcBuildingStorey ]"
	Annotations: bim:ABNT "[ 4A.07.10.07 ]"
	SubClassOf: bim:Cotas.Gabaritadas


Class: bim:Gabarito.Aéreo
	Annotations: rdfs:label "Gabarito Aéreo"@pt
	Annotations: bim:Definição "Gabarito de altura permitida para realizar voos segurança com UAS (drones). Estabelecido pela ANAC (Agência Nacional de Aviação Civil). Especialmente em regiões próximas a aeroportos."@pt
	Annotations: bim:Definición "Medidor de altura permitido para realizar vuelos seguros con UAS (drones). Establecido por ANAC (Agencia Nacional de Aviación Civil). Especialmente en regiones cercanas a aeropuertos."@es
	Annotations: bim:Definition "Height gauge allowed to perform safe flights with UAS (drones). Established by ANAC (National Civil Aviation Agency). Especially in regions close to airports."@en
	Annotations: bim:Natureza "Espacialidade"@pt
	Annotations: bim:Espécie "Elementos Horizontais"@pt
	Annotations: bim:Tema "Cotas Gabaritadas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-ESP-18"
	Annotations: bim:CatRevit "[ OST_Levels , OST_LevelHeads ]"
	Annotations: bim:ClasseIfc "[ IfcBuildingStorey ]"
	Annotations: bim:ABNT "[ 4A.07.10.07 ]"
	SubClassOf: bim:Cotas.Gabaritadas


Class: bim:Gabarito.Hídrico
	Annotations: rdfs:label "Gabarito Hídrico"@pt
	Annotations: bim:Definição "Gabarito que define o nível de um corpo de água natural como o mar ou níveis de crescentes máximas e mínimas de rios ou lagoas. Referência para projetos em zonas litorais ou alagáveis."@pt
	Annotations: bim:Definición "Plantilla que define el nivel de un cuerpo de agua natural como el mar o los niveles máximos y mínimos de ascenso de ríos o lagunas. Referencia para proyectos en zonas costeras o inundables."@es
	Annotations: bim:Definition "Template that defines the level of a natural body of water such as the sea or maximum and minimum rising levels of rivers or lagoons. Reference for projects in coastal or floodable areas."@en
	Annotations: bim:Natureza "Espacialidade"@pt
	Annotations: bim:Espécie "Elementos Horizontais"@pt
	Annotations: bim:Tema "Cotas Gabaritadas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-ESP-19"
	Annotations: bim:CatRevit "[ OST_Levels , OST_LevelHeads ]"
	Annotations: bim:ClasseIfc "[ IfcBuildingStorey ]"
	Annotations: bim:ABNT "[ 4A.07.10.07 ]"
	SubClassOf: bim:Cotas.Gabaritadas


Class: bim:Gabarito.Municipal
	Annotations: rdfs:label "Gabarito Municipal"@pt
	Annotations: bim:Definição "Gabarito de altura máxima permitida para as edificações em cada área urbana. Estabelecido por leis municipais de uso e ocupação do solo. Não pode ser ultrapassado pelo projeto."@pt
	Annotations: bim:Definición "El medidor máximo permitido para edificios en cada área urbana. Establecido por leyes municipales para el uso y ocupación del suelo. No puede ser superado por el proyecto."@es
	Annotations: bim:Definition "Maximum height gauge allowed for buildings in each urban area. Established by municipal laws for land use and occupation. It cannot be exceeded by the project."@en
	Annotations: bim:Natureza "Espacialidade"@pt
	Annotations: bim:Espécie "Elementos Horizontais"@pt
	Annotations: bim:Tema "Cotas Gabaritadas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-ESP-20"
	Annotations: bim:CatRevit "[ OST_Levels , OST_LevelHeads ]"
	Annotations: bim:ClasseIfc "[ IfcBuildingStorey ]"
	Annotations: bim:ABNT "[ 4A.07.10.07 ]"
	SubClassOf: bim:Cotas.Gabaritadas


Class: bim:Elementos.de.Elevações
	Annotations: rdfs:label "Elementos.de.Elevações"@pt
