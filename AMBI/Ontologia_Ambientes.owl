	Annotations: bim:ClasseIfc "[ IfcSpace ]"
	Annotations: bim:ABNT "[ 4A ]"
	SubClassOf: bim:Ambientes.Culturais


Class: bim:Fundo.do.Palco
	Annotations: rdfs:label "Fundo do Palco"@pt
	Annotations: bim:Definição "Espaço oculto e posterior ao palco, atrás da área de atuação dos artistas. Pode abrigar diversos elementos cenográficos, técnicos e funcionais à peça."@pt
	Annotations: bim:Definición "Espacio oculto y de vuelta al escenario, detrás del área de actuación de artistas. Puede albergar diversos elementos escenográficos, técnicos y funcionales de la obra."@es
	Annotations: bim:Definition "Hidden space and back to the stage, behind the artists' performance area. It can house various scenographic, technical and functional elements to the play."@en
	Annotations: bim:Natureza "Espacialidade"@pt
	Annotations: bim:Espécie "Elementos Espaciais"@pt
	Annotations: bim:Tema "Ambientes Culturais"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
