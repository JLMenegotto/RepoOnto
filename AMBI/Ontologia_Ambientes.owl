	Annotations: bim:Definição "Espaço frontal do palco, próximo à plateia. Integra arquitetonicamente à cena cumprindo funções estéticas e acústicas, chamada também de boca de cena."@pt
	Annotations: bim:Definición "Espacio frontal del escenario, cerca del público. Se integra arquitectónicamente con la escena, cumpliendo funciones estéticas y acústicas, también llamada boca del escenario."@es
	Annotations: bim:Definition "Front space of the stage, close to the audience. It integrates architecturally to the scene, fulfilling aesthetic and acoustic functions, also called the stage mouth."@en
	Annotations: bim:Natureza "Espacialidade"@pt
	Annotations: bim:Espécie "Elementos Espaciais"@pt
	Annotations: bim:Tema "Ambientes Culturais"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-ESP-116"
	Annotations: bim:CatRevit "[ OST_Rooms , OST_MEPSpaces ]"
	Annotations: bim:ClasseIfc "[ IfcSpace ]"
	Annotations: bim:ABNT "[ 4A ]"
	SubClassOf: bim:Ambientes.Culturais


Class: bim:Palco
	Annotations: rdfs:label "Palco"@pt
	Annotations: bim:Definição "Espaço exposto aos espectadores, onde os atores se apresentam. Pode ser elevado, plano, giratório, italiano, arena, entre outros formatos."@pt
	Annotations: bim:Definición "Espacio expuesto a los espectadores, donde actúan los actores. Puede ser elevado, plano, giratorio, italiano, arena, entre otros formatos."@es
	Annotations: bim:Definition "Space exposed to spectators, where the actors perform. It can be elevated, flat, rotating, Italian, arena, among other formats."@en
	Annotations: bim:Natureza "Espacialidade"@pt
