                    rdfs:subPropertyOf      bim:BIMProp  .


bim:é.transmitância.térmica   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.energizar ;
                    rdfs:domain             bim:BIM ;
                    rdfs:range              bim:Projeto ;
                    rdfs:label              "Propriedade destinada a energizar: é.transmitância.térmica" ;
                    bim:Chave               "energ.115" ;
                    bim:Ação                "Ação energizar" ;
                    bim:Definição           "Mede a quantidade de calor que atravessa um elemento construtivo por unidade de área e por diferença de temperatura. Expressada em W/m²·K (Watts por metro quadrado vezes Kelvin). A menor transmitância, melhor isolamento."@pt ;
                    bim:Definición          "Mide la cantidad de calor que pasa a través de un elemento de construcción por unidad de área y por diferencia de temperatura. Expresado en W/m²· K (Vatios por metro cuadrado por Kelvin). Cuanto menor transmitancia, mejor aislamiento."@es ;bim:Definition          "It measures the amount of heat that passes through a construction element per unit area and per temperature difference. Expressed in W/m²· K (Watts per square meter times Kelvin). The lower transmittance, better insulation."@en ;
                    owl:inverseOf           bim:é.resistência.térmica  .


