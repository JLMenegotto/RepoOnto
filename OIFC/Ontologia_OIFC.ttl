bim:É.Raiz3  rdf:type  owl:NamedIndividual , bim:Ifc.Hierarquia ;
     bim:é.dentro.de    bim:É.Raiz2 ;
     bim:descrição    "É Raiz de Nivel 3 do IFC. Está embaixo da Raiz de Nível 2."  .

bim:É.Raiz4  rdf:type  owl:NamedIndividual , bim:Ifc.Hierarquia ;
