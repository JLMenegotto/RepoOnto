bim:Explica.DadoSgl  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:dado.ifc    "P_SINGLEVALUE" ;
     bim:descrição    "São dados que admitem um valor único, que pode ser um número, um texto ou valor binário" ;
     bim:descrição    "Representa o valor de uma propriedade que usa um único valor  que pode ser numérico ou descritivo"  .

bim:Explica.DadoEnu  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:dado.ifc    "P_ENUMERATEDVALUE" ;
     bim:descrição    "São dados que representan tipos enumerados. Sempre são valores textuais xs:string" ;
     bim:descrição    "Representa uma lista de tipos predefinidos de classes de objetos. Incluem as opções de OTHER, UNSET e NOTKNOWN"  .

bim:Explica.DadoRef  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:dado.ifc    "P_REFERENCEVALUE" ;
     bim:descrição    "São dados que admitem valor de referência"  .

bim:Explica.DadoBou  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:dado.ifc    "P_BOUNDEDVALUE" ;
     bim:descrição    "São dados que admitem valores limitados entre um valor Mínimo e Máximo"  .

bim:Explica.DadoTab  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:dado.ifc    "P_TABLEVALUE" ;
     bim:descrição    "São dados que representan valores em Tabelas"  .

bim:Explica.DadoLis  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:dado.ifc    "P_LISTVALUE" ;
     bim:descrição    "São dados que representan valores em Listas"  .

bim:Explica.DadoCpx  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:dado.ifc    "COMPLEX" ;
     bim:descrição    "São dados que representan valores de números complexos"  .

bim:Explica.Pro  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "Para relacionar os objetos a suas propriedades às entidades IfcPropertySet"  .

bim:Explica.Ent  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "As entidades IFC represemtam objetos concretos como paredes, espaços, materiais, geometria, relacionamentos e processos. Elas descrevem como são esses objetos e como se conectam aos outros objetos de um modelo BIM. As Classes das entidades estão ordenadas por domínios específicos. Arquitetura, Estrutura, Sistemas, etc. Podem ser elementos físicos organizados nas raizes IfcElement e sua subordinada IfcBuildingElement, que representam componentes construtivos como IfcWall, IfcSlab, IfcBeam, IfcColumn, IfcDoor, IfcWindow, IfcStair, IfcRailing, IfcFurniture. ou os elementos das instalações prediais IfcDistributionElement (HVAC, elétrica, hidráulica). As entidades podem aparecer em duas formas: como instâncias colocadas no modelo ou como tipos referenciados (Instância  IfcFlowMeter ou tipo IfcFlowMeterType, por exemplo). Outras entidades representam as características no nível geométrico dos objetos dentro de  IfcRepresentation, como IfcShapeRepresentation, IfcExtrudedAreaSolid, IfcFacetedBrep, IfcMappedItem, etc. Permitem que o mesmo objeto tenha múltiplas representações seja em 3D, em 2D, ou de modo Unifilar simplificado. O ordenamento espacial do projeto é representado por entidades cuja raiz é IfcSpatialStructureElement. Elas definem a localização, andares, ambientes e zonas: IfcSite, IfcBuilding, IfcBuildingStorey, IfcSpace. Os relacionamentos conectivos entre entidades são definidos por entidades cuja raiz é IfcRelationship. Elas conectam objetos e definem significados como agregados parte-todo IfcRelAggregates, IfcRelContainedInSpatialStructure (elementos incluídos em espaços), IfcRelDefinesByProperties (relações definidas em propriedades), IfcRelConnectsElements (conexões físicas entre elementos)."  .

bim:Explica.Inf  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "Explicação de Entidades com Informação IFC como medidas, textos, etiquetas, etc"  .

bim:Explica.Sel  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "Explicação de Tipos Selecionados IFC"  .

bim:Explica.Enu  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "Explicação de Enumerações de tipos IFC que são predefinições tipificadas do esquema IFC"  .

bim:Explica.Reg  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "Explicação de Regras IFC. Apenas 2 regras."  .

bim:Explica.Fun  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "Explicação de Funções IFC. Executam operações vetoriais ou de cálculo em geral"  .

bim:Explica.Qto  rdf:type  owl:NamedIndividual , bim:Ifc.Explica ;
     bim:descrição    "Representar informações quantitativas de modelos de informação da construção. Os QTOs definem uma forma consistente de medir, calcular e relatar quantidades físicas de elementos construtivos, como comprimento, área, volume, peso e contagem. Essas quantidades são essenciais para estimativas de custo, planejamento, aquisição de materiais e outras atividades de gestão da construção."  .

bim:É.Raiz0  rdf:type  owl:NamedIndividual , bim:Ifc.Hierarquia ;
     bim:descrição    "É a Raiz Principal do IFC. Representada pela entidade IfcRoot."  .

bim:É.Raiz1  rdf:type  owl:NamedIndividual , bim:Ifc.Hierarquia ;
     bim:é.dentro.de    bim:É.Raiz0 ;
