      rdfs:subClassOf  bim:Esquema ;
      rdfs:label  "Ifc Natureza"@pt  .


bim:Ifc.Natureza rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:IFC ;
      rdfs:label  "Ifc.Natureza"@pt ;
      bim:Definição   "Declara a natureza de um Indivíduo da Ontologia IFC. Por exemplo, IfcWall é uma Instância e IfcWallType é um Tipo. Podem ser atribuídas mais de uma natureza aos indivíduos. Por Exemplo, IfcWall é uma Instância de natureza Física. Ou seja tem uma materialidade definida no modelo. IfcWallTypeEnum é de natureza Enumerativa e Virtual, pois embora haja vários tipos de paredes predefinidas como tipo, elas são representações ainda virtuais para o projeto."@pt ;
      bim:Definición  "Declara la naturaleza de un individuo con ontología IFC. Por ejemplo, IfcWall es una Instancia e IfcWallType es un Tipo. Se puede atribuir a más de una naturaleza a los individuos. Por ejemplo, IfcWall es una Instancia de Naturaleza Física. Es decir, tiene una materialidad definida en el modelo. IfcWallTypeEnum es de naturaleza enumerativa y virtual, porque aunque existen varios tipos de muros predefinidos como tipos, siguen siendo representaciones virtuales para el proyecto."@es ;
       bim:Definition  "Declares the nature of an IFC Ontology Individual. For example, IfcWall is an Instance and IfcWallType is a Type. More than one nature can be attributed to individuals. For example, IfcWall is an Instance of Physical nature. That is, it has a materiality defined in the model. IfcWallTypeEnum is Enumerative and Virtual in nature, because although there are several types of predefined walls as a type, they are still virtual representations for the project."@en ;
      bim:Natureza    "Interoperabilidade"@pt ;
      bim:Espécie     "Esquema"@pt ;
      bim:Tema        "Ifc.Natureza"@pt ;
      bim:Disciplina  "Interoperabilidade"@pt ;
      bim:Chave       "Key-IFC43-13"@pt  .


