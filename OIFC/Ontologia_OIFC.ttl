      rdfs:label  "Ifc.Hierarquia"@pt ;
      bim:Definição   "Declara a que nível da Hierarquia corresponde o Elemento IFC, por Exemplo IfcRoot = 0, IfcObjectDefinition = 1, IfcObject = 2, etc..."@pt ;
      bim:Definición  "Declara a qué nivel de la Jerarquía corresponde el Elemento IFC, por ejemplo IfcRoot = 0, IfcObjectDefinition = 1, IfcObject = 2, etc..."@es ;
