ObjectProperty: bim:p.sensorizar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.sensor.térmico
	SubPropertyOf: bim:p.sensorizar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a sensorizar: é.sensor.térmico"@pt
	Annotations: bim:Chave "senso.101"
	Annotations: bim:Ação "Ação sensorizar"@pt
	Annotations: bim:Definição "ID de Revit ou GlobalId IFC ou identificador único de objeto. Identificação de um sensor de temperatura e umidade."@pt
	Annotations: bim:Definición "ID de Revit o GlobalId IFC o identificador de objeto único. Identificación de un sensor de temperatura y humedad."@es
	Annotations: bim:Definition "Revit ID or IFC GlobalId or unique object identifier. Identification of a temperature and humidity sensor."@en
	Annotations: bim:CatRevit "OST_SecurityDevices"
	Annotations: bim:ClasseIfc "IfcSensor"
	EquivalentTo: bim:é.câmera.termográfica

DataProperty: bim:d.sensorizar
