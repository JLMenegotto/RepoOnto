      rdfs:subClassOf  bim:Telecom.Móvil ;
      rdfs:label  "Mobile.Switch.In"@pt ;
      bim:Definição   "O centro de comutação móvel (msc) constitui a interface entre o sistema de rádio e o sistema de comutação fixa."@pt ;
      bim:Definición  "El centro móvil de conmutación (MSC) es la interfaz entre el sistema radioeléctrico y el sistema de conmutación fijo."@es ;
       bim:Definition  "The mobile switching centre (MSC) is the interface between the radio system and the fixed switching system."@en ;
      bim:Natureza    "Comunicação"@pt ;
      bim:Espécie     "Elementos.de.Telecom"@pt ;
      bim:Tema        "Telecom.Móvil"@pt ;
      bim:Disciplina  "Instalações"@pt ;
      bim:Chave       "Key-COM-74"@pt ;
      bim:CatRevit    "[ OST_CommunicationDevices ]"   ;
      bim:ClasseIfc   "[ IfcMobileTelecommunicationsApplianceMOBILESWITCHIN ]"   ;
      bim:ABNT        "[ 3E.34 ]"    .


