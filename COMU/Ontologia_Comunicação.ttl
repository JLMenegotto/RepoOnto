	  rdfs:label "Prédio: -"@pt ;
	  rdfs:label "Cidade: -"@pt ;
	  rdfs:label "Explicação: Formalizar elementos do projeto BIM de objetos de projeto de Comunicação, incluíndo Telecom, Audio e Vídeo e Comunicação Visual."@pt ;
	  rdfs:label "Explicación: Formalización  de elementos de un projeto BIM para Comunicación, incluyendo Telecom, Audio y Vídeo y Comunicación Visual."@es ;
	  rdfs:label "Explanation: Formalize BIM design elements of Communication project objects, including Telecom, Audio and Video and Visual Communication."@en .

rdf:PlainLiteral        rdf:type  rdfs:Datatype .
