	Annotations: bim:ClasseIfc "[ IfcAudioVisualApplianceCAMERA ]"
	Annotations: bim:ABNT "[ 3E.34 ]"
	SubClassOf: bim:Aparelhos.Avi


Class: bim:Comunicador
	Annotations: rdfs:label "Comunicador"@pt
	Annotations: bim:Definição "Terminal de comunicação é um dispositivo de comunicação de áudio que geralmente é instalado ao longo do transporte."@pt
	Annotations: bim:Definición "El terminal de comunicación es un dispositivo de comunicación de audio que generalmente se instala a lo largo del transporte."@es
	Annotations: bim:Definition "Communication terminal is an audio communication device that is usually installed along transportation."@en
	Annotations: bim:Natureza "Comunicação"@pt
	Annotations: bim:Espécie "Elementos.de.AudioVideo"@pt
	Annotations: bim:Tema "Aparelhos.Avi"@pt
	Annotations: bim:Disciplina "Instalações"@pt
	Annotations: bim:Chave "Key-COM-6"
	Annotations: bim:CatRevit "[ OST_AudioVisualDevices , OST_CommunicationDevices ]"
	Annotations: bim:ClasseIfc "[ IfcAudioVisualApplianceCOMMUNICATIONTERMINAL ]"
	Annotations: bim:ABNT "[ 3E.34 ]"
	SubClassOf: bim:Aparelhos.Avi


Class: bim:Monitor
	Annotations: rdfs:label "Monitor"@pt
	Annotations: bim:Definição "Dispositivo eletrônico que representa informações em forma visual, como uma tela plana."@pt
	Annotations: bim:Definición "Un dispositivo electrónico que representa información en forma visual, como una pantalla plana."@es
	Annotations: bim:Definition "An electronic device that represents information in visual form, such as a flat screen."@en
