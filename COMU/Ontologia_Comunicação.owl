Class: bim:Aparelho.Avi
	Annotations: rdfs:label "Aparelho.Avi"@pt
	Annotations: bim:Definição "Aparelho audiovisual é um dispositivo que exibe, captura, transmite ou recebe áudio ou vídeo."@pt
	Annotations: bim:Definición "Un dispositivo audiovisual es un dispositivo que muestra, captura, transmite o recibe audio o vídeo."@es
	Annotations: bim:Definition "An audio-visual device is a device that displays, captures, transmits, or receives audio or video."@en
	Annotations: bim:Natureza "Comunicação"@pt
	Annotations: bim:Espécie "Elementos.de.AudioVideo"@pt
	Annotations: bim:Tema "Aparelhos.Avi"@pt
	Annotations: bim:Disciplina "Instalações"@pt
	Annotations: bim:Chave "Key-COM-3"
	Annotations: bim:CatRevit "[ OST_AudioVisualDevices ]"
	Annotations: bim:ClasseIfc "[ IfcAudioVisualAppliance ]"
	Annotations: bim:ABNT "[ 3E.34 ]"
	SubClassOf: bim:Aparelhos.Avi


Class: bim:Amplificador
	Annotations: rdfs:label "Amplificador"@pt
	Annotations: bim:Definição "Dispositivo que recebe um sinal de áudio e o amplifica para ser reproduzido por meio de alto-falantes."@pt
	Annotations: bim:Definición "Un dispositivo que recibe una señal de audio y la amplifica para ser reproducida a través de altavoces."@es
	Annotations: bim:Definition "A device that receives an audio signal and amplifies it to be played through speakers."@en
	Annotations: bim:Natureza "Comunicação"@pt
	Annotations: bim:Espécie "Elementos.de.AudioVideo"@pt
	Annotations: bim:Tema "Aparelhos.Avi"@pt
	Annotations: bim:Disciplina "Instalações"@pt
	Annotations: bim:Chave "Key-COM-4"
	Annotations: bim:CatRevit "[ OST_AudioVisualDevices ]"
	Annotations: bim:ClasseIfc "[ IfcAudioVisualApplianceAMPLIFIER ]"
	Annotations: bim:ABNT "[ 3E.34 ]"
	SubClassOf: bim:Aparelhos.Avi


Class: bim:Câmera
	Annotations: rdfs:label "Câmera"@pt
	Annotations: bim:Definição "Dispositivo que grava imagens, seja como uma fotografia estática ou como imagens em movimento."@pt
	Annotations: bim:Definición "Un dispositivo que graba imágenes, ya sea como una fotografía fija o como imágenes en movimiento."@es
	Annotations: bim:Definition "A device that records images, either as a still photograph or as moving images."@en
	Annotations: bim:Natureza "Comunicação"@pt
	Annotations: bim:Espécie "Elementos.de.AudioVideo"@pt
	Annotations: bim:Tema "Aparelhos.Avi"@pt
