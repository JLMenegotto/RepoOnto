ObjectProperty: bim:é.sensor.térmico
	SubPropertyOf: bim:p.sensorizar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a sensorizar: é.sensor.térmico"@pt
	Annotations: bim:Chave "senso.101"
