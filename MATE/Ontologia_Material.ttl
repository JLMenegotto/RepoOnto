bim:é.câmera.termográfica   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.sensorizar ;
                    rdfs:domain             bim:BIM ;
                    rdfs:range              bim:Projeto ;
                    rdfs:label              "Propriedade destinada a sensorizar: é.câmera.termográfica" ;
                    bim:Chave               "d.senso.101" ;
                    bim:Ação                "Ação de sensorizar" ;
                    bim:Definição           "Declara o ID de Revit ou GlobalId IFC ou identificador único de objeto. Declara uma câmera termográfica. Sensor para medição de temperatura que exibe termograma ou imagem térmica do objeto emissor da energia infravermelha. Usadas para detectar problemas de superaquecimento de equipamentos, presença de umidade em paredes, etc. "@pt ;
                    bim:Definición          "Declara el ID de Revit o IFC GlobalId o un identificador único de objeto. Identifica una cámara de imagen térmica. Sensor para la medición de temperatura que muestra un termograma o imagen térmica del objeto que emite energía infrarroja. Se usa para detectar problemas como sobrecalentamiento del equipo, presencia de humedad en las paredes, etc."@es ;bim:Definition          "It declares the Revit ID or IFC GlobalId or unique object identifier. Identifies a thermal imaging camera. Sensor for temperature measurement that displays thermogram or thermal image of the object emitting infrared energy. Used to detect problems of equipment overheating, presence of moisture in walls, etc."@en ;
                    bim:CatRevit            "[ OST_SecurityDevices ]" ;
                    bim:ClasseIfc           "[ IfcSensor ]" ;
                    owl:equivalentProperty  bim:é.sensor.térmico  .


