bim:Mármore rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Pedras ;
      rdfs:label  "Mármore"@pt ;
      bim:Definição   "Originada em calcários submetidos a altas pressões e temperaturas. Composto principalmente por calcita. Textura cristalina, veios decorativos, mais poroso que o granito. Usada em bancadas, pisos, revestimentos."@pt ;
      bim:Definición  "Originado en calizas sometidas a altas presiones y temperaturas. Compuesto principalmente de calcita. Textura cristalina, vetas decorativas, más porosas que el granito. Usado en encimeras, suelos, recubrimientos."@es ;
       bim:Definition  "Originated in limestones subjected to high pressures and temperatures. Composed mainly of calcite. Crystalline texture, decorative veins, more porous than granite. Used in countertops, floors, coatings."@en ;
      bim:Natureza    "Materialidade"@pt ;
      bim:Espécie     "Matéria Pétrea"@pt ;
      bim:Tema        "Pedras"@pt ;
      bim:Disciplina  "Projeto"@pt ;
      bim:Chave       "Key-MAT-163"@pt ;
      bim:CatRevit    "[ OST_Material ]"   ;
      bim:ClasseIfc   "[ IfcMaterial ]"   ;
      bim:ABNT        "[ 0M.20.10.01.03 ]"    .


