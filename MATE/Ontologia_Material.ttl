bim:Arenito rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Pedras ;
      rdfs:label  "Arenito"@pt ;
      bim:Definição   "Originada em compactação e cimentação de grãos de areia. Composta principalmente por quartzo e feldspato, cimentados por sílica, carbonato ou óxidos de ferro. É porosa e com cores variadas. Usada em revestimentos e reservatórios de água e petróleo."@pt ;
      bim:Definición  "Se originó en la compactación y cementación de granos de arena. Compuesto principalmente por cuarzo y feldespato, cementado por sílice, carbonato o óxidos de hierro. Es poroso y de colores variados. Se utiliza en recubrimientos y depósitos de agua y petróleo."@es ;
       bim:Definition  "Originated in compaction and cementation of sand grains. Composed mainly of quartz and feldspar, cemented by silica, carbonate or iron oxides. It is porous and with varied colors. Used in coatings and water and oil reservoirs."@en ;
      bim:Natureza    "Materialidade"@pt ;
      bim:Espécie     "Matéria Pétrea"@pt ;
      bim:Tema        "Pedras"@pt ;
      bim:Disciplina  "Projeto"@pt ;
      bim:Chave       "Key-MAT-174"@pt ;
      bim:CatRevit    "[ OST_Material ]"   ;
      bim:ClasseIfc   "[ IfcMaterial ]"   ;
      bim:ABNT        "[ 0M.20.10.01.50.03 ]"    .


