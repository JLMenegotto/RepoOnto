bim:Travertino rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Pedras ;
      rdfs:label  "Travertino"@pt ;
      bim:Definição   "Originado em precipitação de carbonato de cálcio em ambientes de águas termais e cavernas. Composta por calcita, aragonita e limonita. Porosa com veios marcantes, tons bege a marrom. Usada para valorizar revestimentos internos e externos, pisos, escadas, colunas."@pt ;
      bim:Definición  "Se originó en la precipitación de carbonato cálcico en ambientes de aguas termales y cuevas. Compuesto de calcita, aragonita y limonita. Poroso con vetas llamativas, tonos beige a marrones. Se utiliza para realzar recubrimientos internos y externos, suelos, escaleras, columnas."@es ;
       bim:Definition  "Originated in calcium carbonate precipitation in hot spring environments and caves. Composed of calcite, aragonite and limonite. Porous with striking veins, beige to brown tones. Used to enhance internal and external coatings, floors, stairs, columns."@en ;
      bim:Natureza    "Materialidade"@pt ;
      bim:Espécie     "Matéria Pétrea"@pt ;
      bim:Tema        "Pedras"@pt ;
      bim:Disciplina  "Projeto"@pt ;
      bim:Chave       "Key-MAT-176"@pt ;
      bim:CatRevit    "[ OST_Material ]"   ;
      bim:ClasseIfc   "[ IfcMaterial ]"   ;
      bim:ABNT        "[ 0M.20.10.01 ]"    .


