bim:Ardósia rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Pedras ;
      rdfs:label  "Ardósia"@pt ;
      bim:Definição   "Originada em argila ou xisto submetidos a metamorfismo de baixo grau. Composta por quartzo, mica, clorita. De granulação fina, clivagem em lâminas finas, cores escuras. Usada e telhados, pisos, fachadas, mesas e lousas escolares."@pt ;
      bim:Definición  "Originado en arcilla o lutita sometida a metamorfismo de bajo grado. Compuesto de cuarzo, mica, clorita. De grano fino, se escindira en láminas finas, colores oscuros. Se utiliza en tejados, suelos, fachadas, mesas y pizarras escolares."@es ;
       bim:Definition  "Originated in clay or shale subjected to low-grade metamorphism. Composed of quartz, mica, chlorite. Fine-grained, cleavage into thin sheets, dark colors. Used in roofs, floors, facades, tables and school blackboards."@en ;
      bim:Natureza    "Materialidade"@pt ;
      bim:Espécie     "Matéria Pétrea"@pt ;
      bim:Tema        "Pedras"@pt ;
      bim:Disciplina  "Projeto"@pt ;
      bim:Chave       "Key-MAT-173"@pt ;
      bim:CatRevit    "[ OST_Material ]"   ;
      bim:ClasseIfc   "[ IfcMaterial ]"   ;
      bim:ABNT        "[ 0M.20.10.01.50 ]"    .


