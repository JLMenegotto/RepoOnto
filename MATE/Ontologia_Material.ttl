bim:Granito rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Pedras ;
      rdfs:label  "Granito"@pt ;
      bim:Definição   "Originada em rocha magmática intrusiva formada pelo resfriamento lento do magma. Composta por Quartzo, mica e feldspato. Muito dura, resistente, cores variadas (cinza, rosa, preto)Usada em bancadas, pisos, revestimentos, fachadas e monumentos."@pt ;
      bim:Definición  "Se originó en roca magmática intrusiva formada por el lento enfriamiento del magma. Compuesto por cuarzo, mica y feldespato. Muy duro, resistente, de colores variados (gris, rosa, negro). Usado en encimeras, suelos, recubrimientos, fachadas y monumentos."@es ;
       bim:Definition  "Originated in intrusive magmatic rock formed by the slow cooling of magma. Composed of Quartz, mica and feldspar. Very hard, resistant, varied colors (gray, pink, black)Used in countertops, floors, coatings, facades and monuments."@en ;
      bim:Natureza    "Materialidade"@pt ;
      bim:Espécie     "Matéria Pétrea"@pt ;
      bim:Tema        "Pedras"@pt ;
      bim:Disciplina  "Projeto"@pt ;
      bim:Chave       "Key-MAT-162"@pt ;
      bim:CatRevit    "[ OST_Material ]"   ;
      bim:ClasseIfc   "[ IfcMaterial ]"   ;
      bim:ABNT        "[ 0M.20.10.01.01 ]"    .


