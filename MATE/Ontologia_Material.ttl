bim:Basalto rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Pedras ;
      rdfs:label  "Basalto"@pt ;
      bim:Definição   "Originada em lava vulcânica resfriada rapidamente. Composta por silicatos de ferro e magnésio. Cor escura textura fina, muito resistente. Usada em brita para concreto, pavimentação e revestimentos."@pt ;
      bim:Definición  "Se originó en lava volcánica rápidamente enfriada. Compuesto por silicatos de hierro y magnesio. Color oscuro, textura fina, muy resistente. Utilizado en grava para hormigón, pavimentación y recubrimientos."@es ;
       bim:Definition  "Originated in rapidly cooled volcanic lava. Composed of iron and magnesium silicates. Dark color, fine texture, very resistant. Used in gravel for concrete, paving and coatings."@en ;
      bim:Natureza    "Materialidade"@pt ;
      bim:Espécie     "Matéria Pétrea"@pt ;
      bim:Tema        "Pedras"@pt ;
      bim:Disciplina  "Projeto"@pt ;
      bim:Chave       "Key-MAT-175"@pt ;
      bim:CatRevit    "[ OST_Material ]"   ;
      bim:ClasseIfc   "[ IfcMaterial ]"   ;
      bim:ABNT        "[ 0M.20.10.01 ]"    .


