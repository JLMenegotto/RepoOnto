Class: bim:Ar.Condicionado
	Annotations: rdfs:label "Ar.Condicionado"@pt
	Annotations: bim:Definição "Sistema de distribuição de ar condicionado para manter uma gama de temperaturas num ou mais espaço."@pt
	Annotations: bim:Definición "Sistema de distribución de aire acondicionado para mantener un rango de temperaturas en uno o más espacios."@es
	Annotations: bim:Definition "Air conditioning distribution system to maintain a range of temperatures in one or more spaces."@en
	Annotations: bim:Natureza "Climatização"@pt
	Annotations: bim:Espécie "Sistemas.de.Climatização"@pt
	Annotations: bim:Tema "Sistema.Climatizador"@pt
	Annotations: bim:Disciplina "Instalações"@pt
	Annotations: bim:Chave "Key-AVA-10"
	Annotations: bim:CatRevit "[ OST_DuctSystem ]"
	Annotations: bim:ClasseIfc "[ IfcDistributionSystemAIRCONDITIONING ]"
	Annotations: bim:ABNT "[ 3E ]"
	SubClassOf: bim:Sistema.Climatizador


