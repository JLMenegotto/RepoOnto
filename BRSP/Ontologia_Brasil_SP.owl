ObjectProperty: bim:é.base.x
	SubPropertyOf: bim:p.formar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a formar: é.base.x"@pt
	Annotations: bim:Chave "d.forma.108"
	Annotations: bim:Ação "Ação de formar"@pt
	Annotations: bim:Definição "Declara a coordenada X de um ponto usado como primeira base para aplicar uma transformação geométrica. Especialmente usada em definições que usam 1 ponto como rotaçoes ou mudanças de escala."@pt
	Annotations: bim:Definición "Declara la coordenada X de un punto utilizada como primera base para aplicar una transformación geométrica. Especialmente en definiciones que usan 1 punto como rotaciones o cambios de escala."@es
	Annotations: bim:Definition "It declares the X coordinate of a point used as the first base for applying a geometric transformation. Especially used in definitions that use 1 point as rotations or scale changes."@en
	EquivalentTo: bim:é.coordenada.x

