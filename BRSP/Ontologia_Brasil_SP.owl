Class: bim:Marco.de.Fronteira
	Annotations: rdfs:label "Marco.de.Fronteira"@pt
	Annotations: bim:Definição "Representa onde um limite administrativo (cidade ou estado) ou de manutenção (empresas ou regionais diferentes) cruza o elemento linear (trilhos ou estradas) que está sendo medido."@pt
	Annotations: bim:Definición "Representa el punto en el que un límite administrativo (ciudad o estado) o de mantenimiento (diferentes empresas o regiones) interseca el elemento lineal (vías férreas o carreteras) que se está midiendo."@es
	Annotations: bim:Definition "Represents where an administrative (city or state) or maintenance boundary (different companies or regionals) intersects the linear element (rails or roads) being measured."@en
	Annotations: bim:Natureza "Fronteiras"@pt
	Annotations: bim:Espécie "Demarcadas"@pt
	Annotations: bim:Tema "Marcos"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-INF-33"
	Annotations: bim:ClasseIfc "[ IfcReferentINTERSECTION ]"
	SubClassOf: bim:Marcos


Class: bim:Marco.de.Cruzamento
	Annotations: rdfs:label "Marco.de.Cruzamento"@pt
	Annotations: bim:Definição "É a localização de uma interseção especificada pelo nome do referente. o local de intersecção das linhas de referência de ruas da intersecção. não é precisa ou determinística."@pt
	Annotations: bim:Definición "Es la ubicación de una intersección especificada por el nombre del referente. La ubicación de la intersección de las líneas de referencia de calle de la intersección. No es preciso ni determinista."@es
	Annotations: bim:Definition "It is the location of an intersection specified by the name of the referent. the intersection location of the intersection's street reference lines. it is not precise or deterministic."@en
	Annotations: bim:Natureza "Fronteiras"@pt
	Annotations: bim:Espécie "Demarcadas"@pt
	Annotations: bim:Tema "Marcos"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-INF-34"
	Annotations: bim:ClasseIfc "[ IfcReferentPOSITION ]"
	SubClassOf: bim:Marcos


