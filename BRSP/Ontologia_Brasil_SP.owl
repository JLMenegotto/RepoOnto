ObjectProperty: bim:p.energizar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.fator.fotoenergético
	SubPropertyOf: bim:p.energizar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a energizar: é.fator.fotoenergético"@pt
	Annotations: bim:Chave "d.energ.110"
	Annotations: bim:Ação "Ação de energizar"@pt
	Annotations: bim:Definição "Declara a quantidade de energia solar que atravessa o vidro em relação à energia solar que incide sobre ele. Expressado entre 0 a 1. Quanto menor é o valor menos energia atravessa. Equivalente a fator solar."@pt
	Annotations: bim:Definición "Declara la cantidad de energía solar que pasa a través del vidrio en relación con la energía solar que cae sobre él. Expresado entre 0 y 1. Cuanto menor sea el valor, menos energía pasará. Equivalente al factor solar."@es
	Annotations: bim:Definition "It declares the amount of solar energy that passes through the glass in relation to the solar energy that falls on it. Expressed between 0 to 1. The lower the value, the less energy it passes through. Equivalent to solar factor."@en
	EquivalentTo: bim:é.fator.solar

