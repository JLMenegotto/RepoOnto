Class: bim:Região.Intermediária
	Annotations: rdfs:label "Região Intermediária"@pt
	Annotations: bim:Definição "Região Geográfica Intermediária. Definidas pelo IBGE do Brasil há 133 Regiões Geográficas Intermediárias, de escala maior, são articuladas por capitais regionais ou grandes centros urbanos."@pt
	Annotations: bim:Definición "Región geográfica intermedia. Definidas por el IBGE de Brasil, existen 133 Regiones Geográficas Intermedias, de mayor escala, que se articulan por capitales regionales o grandes centros urbanos."@es
	Annotations: bim:Definition "Intermediate Geographic Region. Defined by the IBGE of Brazil, there are 133 Intermediate Geographic Regions, of a larger scale, which are articulated by regional capitals or large urban centers."@en
	Annotations: bim:Natureza "Fronteiras"@pt
	Annotations: bim:Espécie "Geográficas"@pt
	Annotations: bim:Tema "Políticas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-INF-20"
	Annotations: bim:ClasseIfc "[ IfcZone ]"
	SubClassOf: bim:Políticas
	EquivalentTo:  bim:é.dentro.de some bim:País


Class: bim:Região.Imediata
	Annotations: rdfs:label "Região Imediata"@pt
	Annotations: bim:Definição "Região Geográfica Imediata. Definidas pelo IBGE do Brasil há 510 Regiões Geográficas de escala menor, são articuladas por cidades médias e pequenas."@pt
	Annotations: bim:Definición "Región geográfica inmediata. Definida por el IBGE de Brasil, hay 510 regiones geográficas de menor escala, articuladas por ciudades medianas y pequeñas."@es
	Annotations: bim:Definition "Immediate geographic region. Defined by the IBGE of Brazil, there are 510 Geographic Regions of smaller scale, they are articulated by medium and small cities."@en
	Annotations: bim:Natureza "Fronteiras"@pt
	Annotations: bim:Espécie "Geográficas"@pt
	Annotations: bim:Tema "Políticas"@pt
	Annotations: bim:Disciplina "Arquitetura"@pt
	Annotations: bim:Chave "Key-INF-21"
	Annotations: bim:ClasseIfc "[ IfcZone ]"
