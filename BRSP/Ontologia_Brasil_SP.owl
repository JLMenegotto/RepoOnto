	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a qualificar: é.positiva"@pt
	Annotations: bim:Chave "d.quali.152"
	Annotations: bim:Ação "Ação de qualificar"@pt
	Annotations: bim:Definição "Declara que um elemento que é positiva. Como pressurização positiva para impedir o ingresso de particulado contaminante ou uma armadura estrutural."@pt
	Annotations: bim:Definición "Declara a un elemento que es positivo. Como presurización positiva para evitar la entrada de partículas contaminantes."@es
	Annotations: bim:Definition "It declares an element that is positive. As positive pressurization to prevent the ingress of contaminating particulates."@en
	InverseOf: bim:é.negativa

